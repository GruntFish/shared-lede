# CONFIG_PACKAGE_luci-theme-material is not set
# CONFIG_PACKAGE_luci-theme-openwrt is not set
# CONFIG_PACKAGE_luci-theme-openwrt-2020 is not set

# Kernel modules - USB Support (全部为新增项)
CONFIG_PACKAGE_kmod-usb-core=y # ↑ 新增：USB核心支持
CONFIG_PACKAGE_kmod-usb-ohci=y # ↑ 新增：USB 1.1控制器支持
CONFIG_PACKAGE_kmod-usb2=y # ↑ 新增：USB 2.0控制器支持（MT7621必选）
CONFIG_PACKAGE_kmod-usb3=y # ↑ 新增：USB 3.0控制器支持（如果有USB3.0接口）
CONFIG_PACKAGE_kmod-usb-storage=y # ↑ 新增：USB存储设备支持（U盘、移动硬盘）
CONFIG_PACKAGE_kmod-usb-storage-extras=y # ↑ 新增：支持更多USB存储设备
CONFIG_PACKAGE_kmod-scsi-core=y # ↑ 新增：SCSI设备支持（现代USB硬盘需要）

# Kernel modules - Filesystem Support (全部为新增项)
CONFIG_PACKAGE_kmod-fs-ext4=y # ↑ 新增：ext4文件系统支持（Linux格式）
CONFIG_PACKAGE_kmod-fs-vfat=y # ↑ 新增：FAT32/VFAT文件系统支持（U盘常用）
CONFIG_PACKAGE_kmod-fs-ntfs=y # ↑ 新增：NTFS文件系统支持（Windows硬盘，只读）
CONFIG_PACKAGE_ntfs-3g=y # ↑ 新增：NTFS读写支持（完整NTFS功能）
CONFIG_PACKAGE_kmod-fs-exfat=y # ↑ 新增：exFAT文件系统支持（大容量U盘/SD卡）
CONFIG_PACKAGE_kmod-fs-cifs=y # ↑ 新增：CIFS/SMB网络文件系统客户端支持（挂载网络共享）

# Kernel modules - charset (全部为新增项)
CONFIG_PACKAGE_kmod-nls-cp437=y # ↑ 新增：Codepage 437，避免FAT中文乱码
CONFIG_PACKAGE_kmod-nls-iso8859-1=y # ↑ 新增：ISO 8859-1，避免FAT中文乱码
CONFIG_PACKAGE_kmod-nls-utf8=y # ↑ 新增：UTF-8编码支持，彻底解决中文乱码问题

# Base system - Block Support (新增项)
CONFIG_PACKAGE_blockd=y # ↑ 新增：自动挂载和块设备管理服务（必选）

# Utilities - filesystem (新增CIFS相关)
CONFIG_PACKAGE_cifsmount=y # ↑ 新增：CIFS挂载工具
CONFIG_PACKAGE_samba4-libs=y # ↑ 新增：Samba4库文件支持
CONFIG_PACKAGE_samba4-server=y # ↑ 新增：Samba4服务器（提供SMB共享服务）
CONFIG_PACKAGE_samba4-utils=y # ↑ 新增：Samba4工具集

